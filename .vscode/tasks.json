{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ship (PR → auto-merge)",
      "type": "process",
      "command": "cmd.exe",
      "args": ["/c", "${workspaceFolder}\\deploy.cmd"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Ship (dry run)",
      "type": "process",
      "command": "cmd.exe",
      "args": ["/c", "${workspaceFolder}\\deploy.cmd", "-DryRun"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy",
      "type": "process",
      "command": "cmd.exe",
      "args": ["/c", "${workspaceFolder}\\deploy.cmd"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
